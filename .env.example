# ─── Supabase ────────────────────────────────────────────────────────────────
# All three come from Supabase Dashboard → Project Settings → API.

# Project URL (looks like https://abcdefghijklmn.supabase.co)
SUPABASE_URL=

# service_role / secret key — backend uses this for DB writes (bypasses RLS).
# DO NOT expose this to the frontend.
SUPABASE_KEY=

# anon / public key — frontend uses this for sign-in / sign-up / OAuth calls.
# Safe to expose to the browser; RLS protects the data.
SUPABASE_ANON_KEY=

# JWT secret — ONLY needed for legacy HS256 projects. Modern Supabase
# projects use asymmetric signing keys (ES256); the backend fetches the
# public key from {SUPABASE_URL}/auth/v1/.well-known/jwks.json automatically.
# Leave blank unless your project still uses the legacy shared secret.
SUPABASE_JWT_SECRET=

# Where Google should redirect after OAuth login. Match this to your Streamlit URL.
# Must also be added to Supabase Dashboard → Authentication → URL Configuration.
AUTH_REDIRECT_URL=http://localhost:8501

# ─── Other services ──────────────────────────────────────────────────────────
GROQ_API_KEY=
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2
